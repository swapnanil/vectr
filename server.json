{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.swapnanil/vectr",
  "title": "Vectr",
  "description": "Semantic codebase search + persistent working memory for AI code editors. Local, no API key.",
  "repository": {
    "url": "https://github.com/swapnanil/vectr",
    "source": "github"
  },
  "websiteUrl": "https://swapnanilsaha.com/tools/vectr",
  "version": "1.5.0",
  "packages": [
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "vectr",
      "version": "1.5.0",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp-stdio",
          "description": "Serve MCP over stdio for the workspace in the current directory."
        }
      ]
    },
    {
      "registryType": "pypi",
      "registryBaseUrl": "https://pypi.org",
      "identifier": "vectr",
      "version": "1.5.0",
      "transport": {
        "type": "streamable-http",
        "url": "http://localhost:{VECTR_PORT}/mcp"
      },
      "environmentVariables": [
        {
          "name": "VECTR_PORT",
          "description": "Port the local vectr daemon serves MCP on. Start the daemon with `vectr start` before connecting.",
          "isRequired": false,
          "isSecret": false,
          "default": "8765"
        }
      ]
    }
  ]
}