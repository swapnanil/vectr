# Embedding model — local (default, no API key needed) or cloud
# Local: jinaai/jina-embeddings-v2-base-code (~550MB, cached after first download at ~/.cache/vectr/)
# Cloud: voyage-code-2 (requires VOYAGE_API_KEY) | openai/text-embedding-3-small (requires OPENAI_API_KEY)
VECTR_EMBED_MODEL=jinaai/jina-embeddings-v2-base-code

# API keys — only needed for cloud embedding or optional LLM summary generation
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
VOYAGE_API_KEY=your_key_here

# Port for Vectr MCP server (default: 8765, chosen to avoid conflict with common dev servers)
VECTR_PORT=8765

# LLM model for optional module summary generation (default: claude-sonnet-4-6)
# Claude: claude-sonnet-4-6 | claude-haiku-4-5-20251001 | claude-opus-4-7
# OpenAI: gpt-4o | gpt-4o-mini | o3-mini | o4-mini
LLM_MODEL=claude-sonnet-4-6
