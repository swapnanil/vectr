# Embedding model — local (default, no API key needed) or cloud
# Local default: ibm-granite/granite-embedding-english-r2 (~290MB, cached after first download at ~/.cache/vectr/)
# Any sentence-transformers model ID works. Cloud: voyage-code-2 (requires VOYAGE_API_KEY) | openai/text-embedding-3-small (requires OPENAI_API_KEY)
VECTR_EMBED_MODEL=ibm-granite/granite-embedding-english-r2

# API keys — only needed for cloud embedding
OPENAI_API_KEY=your_key_here
VOYAGE_API_KEY=your_key_here

# Port for Vectr MCP server (default: 8765, chosen to avoid conflict with common dev servers)
VECTR_PORT=8765

# ---------------------------------------------------------------------------
# Optional security features — all OFF by default; enabling nothing changes
# nothing. See the README "Security" section and docs/data-handling.md.
# ---------------------------------------------------------------------------

# Require this key on every /v1 and /mcp request (X-Api-Key or Bearer header).
# Generate one with: vectr key
# Required when binding beyond localhost (vectr start --host 0.0.0.0).
#VECTR_API_KEY=

# Encrypt working-memory note content, titles, and snapshot payloads at rest.
# Requires: pip install vectr[encryption]
# Alternative to this env var: store the passphrase in the OS keychain under
# service "vectr", username "encrypt-key".
# NOT covered: the code index (use OS full-disk encryption), tags/metadata.
#VECTR_ENCRYPT_KEY=

# With encryption on, also omit note embedding vectors (a lossy plaintext
# projection of note text kept for semantic recall). Strictest posture;
# recall falls back to exact-text matching.
#VECTR_ENCRYPT_DISABLE_NOTE_VECTORS=1

# Auto-delete working-memory notes older than N days at daemon startup.
# Unset = notes are kept until you delete them.
#VECTR_NOTES_TTL_DAYS=90

# Rotating local audit log of index/search/remember/recall/forget events
# (records query text; local file only, never transmitted). Unset = disabled.
#VECTR_AUDIT_LOG=~/.vectr/audit.log
