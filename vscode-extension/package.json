{
  "name": "vectr",
  "displayName": "Vectr — Semantic Code Search + Working Memory",
  "icon": "icon.png",
  "description": "Zero-config local codebase indexer. Auto-starts when you open a workspace and serves semantic code search and persistent working memory to any MCP-compatible AI code editor.",
  "version": "1.5.0",
  "publisher": "swapnanilsaha",
  "license": "MIT",
  "homepage": "https://swapnanilsaha.com/tools/vectr",
  "bugs": {
    "url": "https://github.com/swapnanil/vectr/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swapnanil/vectr.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other",
    "Machine Learning"
  ],
  "keywords": [
    "ai",
    "codebase",
    "search",
    "mcp",
    "rag",
    "semantic",
    "embeddings",
    "claude",
    "cursor",
    "copilot",
    "context",
    "indexer",
    "local"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vectr.showStatus",
        "title": "Vectr: Show Indexing Status"
      },
      {
        "command": "vectr.reindex",
        "title": "Vectr: Re-index Workspace"
      },
      {
        "command": "vectr.stop",
        "title": "Vectr: Stop Daemon"
      }
    ],
    "configuration": {
      "title": "Vectr",
      "properties": {
        "vectr.port": {
          "type": "number",
          "default": 8765,
          "description": "Preferred starting port for the Vectr MCP server. Actual port may differ if this port is already in use — vectr scans upward until a free port is found."
        },
        "vectr.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the Vectr daemon when a workspace is opened."
        },
        "vectr.embedModel": {
          "type": "string",
          "default": "ibm-granite/granite-embedding-english-r2",
          "description": "Embedding model for semantic search. Default model (~440 MB) runs locally on CPU with no API key required. Override with any HuggingFace sentence-transformers model ID."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
