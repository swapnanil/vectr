+package org.apache.camel.reifier;
+
+import org.apache.camel.Processor;
+import org.apache.camel.Route;
+import org.apache.camel.model.ProcessorDefinition;
+import org.apache.camel.model.TimeboxDefinition;
+import org.apache.camel.processor.TimeboxProcessor;
+
+public class TimeboxReifier extends ProcessorReifier<TimeboxDefinition> {
+
+    public TimeboxReifier(Route route, ProcessorDefinition<?> definition) {
+        super(route, TimeboxDefinition.class.cast(definition));
+    }
+
+    @Override
+    public Processor createProcessor() throws Exception {
+        long timeoutMillis = parseLong(definition.getTimeoutMillis(), 0);
+        if (timeoutMillis <= 0) {
+            throw new IllegalArgumentException("timeoutMillis must be a positive number on timebox: " + definition);
+        }
+
+        Processor childProcessor = this.createChildProcessor(true);
+
+        TimeboxProcessor answer = new TimeboxProcessor(camelContext, childProcessor, timeoutMillis);
+        answer.setId(getId(definition));
+        answer.setRouteId(route.getRouteId());
+        // TimeboxProcessor is always DisabledAware (via BaseDelegateProcessorSupport), no instanceof needed
+        answer.setDisabled(isDisabled(camelContext, definition));
+        return answer;
+    }
+}
