+package org.apache.camel.model;
+
+import java.util.List;
+
+import jakarta.xml.bind.annotation.XmlAccessType;
+import jakarta.xml.bind.annotation.XmlAccessorType;
+import jakarta.xml.bind.annotation.XmlAttribute;
+import jakarta.xml.bind.annotation.XmlElementRef;
+import jakarta.xml.bind.annotation.XmlRootElement;
+
+import org.apache.camel.spi.Metadata;
+
+/**
+ * Bounds the wall-clock time of a sequence of steps to a fixed budget. If the nested outputs have not completed within
+ * the budget, the exchange fails with {@link org.apache.camel.ExchangeTimedOutException}.
+ */
+@Metadata(label = "eip,routing")
+@XmlRootElement(name = "timebox")
+@XmlAccessorType(XmlAccessType.FIELD)
+public class TimeboxDefinition extends OutputDefinition<TimeboxDefinition> {
+
+    @XmlAttribute(required = true)
+    @Metadata(required = true, javaType = "java.lang.Long")
+    private String timeoutMillis;
+
+    public TimeboxDefinition() {
+    }
+
+    public TimeboxDefinition(TimeboxDefinition source) {
+        super(source);
+        this.timeoutMillis = source.timeoutMillis;
+    }
+
+    public TimeboxDefinition(long timeoutMillis) {
+        this.timeoutMillis = Long.toString(timeoutMillis);
+    }
+
+    @Override
+    public TimeboxDefinition copyDefinition() {
+        return new TimeboxDefinition(this);
+    }
+
+    @Override
+    public List<ProcessorDefinition<?>> getOutputs() {
+        return super.getOutputs();
+    }
+
+    @XmlElementRef
+    @Override
+    public void setOutputs(List<ProcessorDefinition<?>> outputs) {
+        super.setOutputs(outputs);
+    }
+
+    @Override
+    public String toString() {
+        return "Timebox[" + timeoutMillis + " millis, " + getOutputs() + "]";
+    }
+
+    @Override
+    public String getShortName() {
+        return "timebox";
+    }
+
+    @Override
+    public String getLabel() {
+        return "timebox[" + timeoutMillis + "]";
+    }
+
+    public String getTimeoutMillis() {
+        return timeoutMillis;
+    }
+
+    /**
+     * The wall-clock budget, in milliseconds, within which the nested outputs must complete. If the budget is exceeded
+     * then the exchange fails with {@link org.apache.camel.ExchangeTimedOutException} carrying the budget, and any
+     * outputs after {@code end()} do not run.
+     */
+    public void setTimeoutMillis(String timeoutMillis) {
+        this.timeoutMillis = timeoutMillis;
+    }
+}
