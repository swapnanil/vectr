+package org.apache.camel.processor;
+
+import java.util.concurrent.ExecutorService;
+import java.util.concurrent.RejectedExecutionException;
+import java.util.concurrent.ScheduledExecutorService;
+import java.util.concurrent.ScheduledFuture;
+import java.util.concurrent.TimeUnit;
+import java.util.concurrent.atomic.AtomicBoolean;
+
+import org.apache.camel.AsyncCallback;
+import org.apache.camel.CamelContext;
+import org.apache.camel.Exchange;
+import org.apache.camel.ExchangeTimedOutException;
+import org.apache.camel.Processor;
+import org.apache.camel.Traceable;
+import org.apache.camel.spi.IdAware;
+import org.apache.camel.spi.RouteIdAware;
+import org.apache.camel.support.ExchangeHelper;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+/**
+ * The processor which implements the <a href="http://camel.apache.org/timebox.html">Timebox</a> EIP: bounds the
+ * wall-clock time of its nested outputs to a fixed budget, failing the {@link Exchange} with
+ * {@link ExchangeTimedOutException} when the budget is exceeded.
+ * <p/>
+ * <b>Isolation.</b> The nested outputs run against a correlated copy of the exchange (see
+ * {@link ExchangeHelper#createCorrelatedCopy(Exchange, boolean)}), never the original. That way a child which is still
+ * running after the budget has already expired cannot mutate or corrupt the exchange that has, by then, already
+ * continued down the route as timed out.
+ * <p/>
+ * <b>Completion/timeout race.</b> Exactly one of "the nested outputs completed" and "the budget expired" may act on the
+ * original exchange. Both paths attempt a single {@code compareAndSet(false, true)} on a per-invocation
+ * {@link AtomicBoolean}; only the winner is allowed to touch the original exchange and invoke the callback, and only a
+ * within-budget completion copies its results (body, headers, properties, variables and any exception) back onto it.
+ * The loser's outcome is simply dropped. Because the child runs through the normal (possibly asynchronous) processing
+ * chain, this also correctly enforces the budget for asynchronous children (for example an async delayer, or a SEDA
+ * round-trip): whichever thread the child eventually completes on still has to win the same compare-and-set race as the
+ * timer.
+ * <p/>
+ * <b>Executor strategy.</b> Deadlines for all in-flight exchanges passing through one timebox instance are tracked on a
+ * single shared {@link ScheduledExecutorService} (one background timer thread, created in {@link #doStart()}), not a
+ * dedicated thread or busy-wait per exchange. So many concurrent exchanges through the same timebox never create more
+ * than that one extra thread.
+ */
+public class TimeboxProcessor extends BaseDelegateProcessorSupport implements Traceable, IdAware, RouteIdAware {
+
+    private static final Logger LOG = LoggerFactory.getLogger(TimeboxProcessor.class);
+
+    private final CamelContext camelContext;
+    private final long timeoutMillis;
+    private String id;
+    private String routeId;
+    private ScheduledExecutorService executorService;
+    private ExecutorService callbackExecutorService;
+
+    public TimeboxProcessor(CamelContext camelContext, Processor processor, long timeoutMillis) {
+        super(processor);
+        this.camelContext = camelContext;
+        this.timeoutMillis = timeoutMillis;
+    }
+
+    @Override
+    public boolean process(final Exchange exchange, final AsyncCallback callback) {
+        if (timeoutMillis <= 0) {
+            // no budget configured: behave as if the timebox was absent
+            return processor.process(exchange, callback);
+        }
+
+        // isolate: the nested outputs never see the real exchange, only a correlated, independent copy of it.
+        // a late-finishing child can therefore only ever mutate this copy, never the exchange the route
+        // continues with
+        final Exchange copy = ExchangeHelper.createCorrelatedCopy(exchange, false);
+
+        // decides, exactly once, whether the timeout or the completion gets to act on the real exchange
+        final AtomicBoolean done = new AtomicBoolean();
+        final ScheduledFuture<?>[] timeoutFuture = new ScheduledFuture<?>[1];
+
+        Runnable onTimeout = () -> {
+            if (done.compareAndSet(false, true)) {
+                if (LOG.isDebugEnabled()) {
+                    LOG.debug("Timebox of {} millis expired for exchangeId: {}", timeoutMillis, exchange.getExchangeId());
+                }
+                exchange.setException(new ExchangeTimedOutException(exchange, timeoutMillis));
+                // dispatch the callback (and whatever synchronous work it triggers downstream, e.g. a
+                // redelivery that reinvokes this very processor with a slow/blocking child) onto a separate
+                // executor rather than running it inline here. this Runnable itself executes on the single
+                // shared scheduling thread that every in-flight exchange's deadline depends on; if arbitrary
+                // downstream work were allowed to run on that same thread, a single blocking child could
+                // starve every other exchange's timeout -- including a subsequent redelivery attempt of this
+                // very exchange, which would otherwise silently never time out at all
+                callbackExecutorService.execute(() -> callback.done(false));
+            }
+            // else: the nested outputs already completed within budget and won the race; nothing more to do
+        };
+
+        try {
+            timeoutFuture[0] = executorService.schedule(onTimeout, timeoutMillis, TimeUnit.MILLISECONDS);
+        } catch (RejectedExecutionException e) {
+            exchange.setException(e);
+            callback.done(true);
+            return true;
+        }
+
+        // tracks whether the completion callback below both (a) won the race against the timeout and (b) was
+        // invoked synchronously, i.e. before processor.process() below has even returned. only in that exact
+        // case can this method itself honestly report synchronous completion back up the AsyncProcessor chain;
+        // reporting it in any other case would violate the AsyncCallback contract (done(true) must never be
+        // signalled after process() has already returned control to the caller)
+        final boolean[] wonSynchronously = new boolean[1];
+
+        boolean childReportedSync = processor.process(copy, doneSync -> {
+            if (done.compareAndSet(false, true)) {
+                ScheduledFuture<?> future = timeoutFuture[0];
+                if (future != null) {
+                    future.cancel(false);
+                }
+                // completion won within budget: copy body, headers, properties, variables and any exception
+                // from the isolated copy back onto the real exchange, preserving its exchange pattern
+                ExchangeHelper.copyResultsPreservePattern(exchange, copy);
+                if (doneSync) {
+                    // still inside processor.process() below: defer signalling the callback to the return
+                    // value of this method instead of calling callback.done() here
+                    wonSynchronously[0] = true;
+                } else {
+                    callback.done(false);
+                }
+            }
+            // else: the timeout already won and has completed the real exchange; this late completion happened
+            // on the isolated copy only, so it is simply dropped and never touches the real exchange
+        });
+
+        if (childReportedSync && wonSynchronously[0]) {
+            // the child ran and completed entirely within this call, well within budget, and nothing else
+            // (in particular the timer) could have won the race in the meantime: report synchronous completion
+            // honestly, exactly like any other processor would for a fast child
+            callback.done(true);
+            return true;
+        }
+
+        // either the child is still running (asynchronous child, or a slow synchronous one blocking a worker
+        // thread), or the timeout already won the race: which side ultimately wins is only known once one of
+        // the two callbacks above has executed its compare-and-set, and that may happen on the timer thread or
+        // the child's own thread -- so reporting synchronous completion here would be incorrect
+        return false;
+    }
+
+    @Override
+    protected void doStart() throws Exception {
+        super.doStart();
+        if (executorService == null) {
+            executorService = camelContext.getExecutorServiceManager().newSingleThreadScheduledExecutor(this, "Timebox");
+        }
+        if (callbackExecutorService == null) {
+            callbackExecutorService = camelContext.getExecutorServiceManager().newDefaultThreadPool(this, "TimeboxCallback");
+        }
+    }
+
+    @Override
+    protected void doShutdown() throws Exception {
+        if (executorService != null) {
+            camelContext.getExecutorServiceManager().shutdownNow(executorService);
+            executorService = null;
+        }
+        if (callbackExecutorService != null) {
+            camelContext.getExecutorServiceManager().shutdownNow(callbackExecutorService);
+            callbackExecutorService = null;
+        }
+        super.doShutdown();
+    }
+
+    @Override
+    public String getId() {
+        return id;
+    }
+
+    @Override
+    public void setId(String id) {
+        this.id = id;
+    }
+
+    @Override
+    public String getRouteId() {
+        return routeId;
+    }
+
+    @Override
+    public void setRouteId(String routeId) {
+        this.routeId = routeId;
+    }
+
+    @Override
+    public String getTraceLabel() {
+        return "timebox[" + timeoutMillis + "]";
+    }
+
+    public long getTimeoutMillis() {
+        return timeoutMillis;
+    }
+
+    @Override
+    public String toString() {
+        return "Timebox[" + timeoutMillis + " millis]";
+    }
+}
